# SentenceTransformer model id (Hugging Face hub) or local path
ST_MODEL_NAME=BAAI/bge-m3

# Optional: cache directory for downloaded models (passed as cache_folder to SentenceTransformer)
ST_MODEL_CACHE_DIR=

# cpu | cuda | cuda:0
ST_DEVICE=cpu

# Uvicorn bind (used by CLI and Docker)
ST_HOST=0.0.0.0
ST_PORT=8000
